{
  "rewrites": [
    {
      "source": "/calculator",
      "destination": "/index.html"
    },
    {
      "source": "/calculator/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/learn",
      "destination": "/learn/index.html"
    },
    {
      "source": "/learn/:page",
      "destination": "/learn/:page.html"
    }
  ]
}